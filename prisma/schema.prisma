// TradeOS Prisma Schema — Complete
// Full database schema for the enterprise trading platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ AUTH & USERS ============

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  password         String
  firstName        String
  lastName         String
  twoFactorEnabled Boolean      @default(false)
  twoFactorSecret  String?
  avatar           String?
  role             UserRole     @default(TRADER)
  status           UserStatus   @default(ACTIVE)
  lastLogin        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organizations    OrgMember[]
  portfolios       Portfolio[]
  trades           Trade[]
  orders           Order[]
  watchlists       Watchlist[]
  agents           AIAgent[]
  notifications    Notification[]
  apiKeys          ExchangeCredential[]
  sessions         Session[]
}

model Organization {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  plan        OrgPlan      @default(FREE)
  status      OrgStatus    @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id])

  members     OrgMember[]
  portfolios  Portfolio[]
  agents      AIAgent[]
  deployments Deployment[]
}

model OrgMember {
  id         String       @id @default(cuid())
  orgId      String
  userId     String
  role       OrgRole      @default(DEVELOPER)
  joinedAt   DateTime     @default(now())

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

enum UserRole {
  ADMIN
  TRADER
  VIEWER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum OrgPlan {
  FREE
  PRO
  ENTERPRISE
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

enum OrgRole {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
}

// ============ PORTFOLIOS & POSITIONS ============

model Portfolio {
  id             String       @id @default(cuid())
  name           String
  description    String?
  initialCapital Float
  currentValue   Float        @default(0)
  currency       String       @default("USD")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  ownerId        String
  owner          User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  orgId          String?
  org            Organization? @relation(fields: [orgId], references: [id])

  positions      Position[]
  trades         Trade[]
  orders         Order[]
  balances       Balance[]
}

model Position {
  id           String       @id @default(cuid())
  symbol       String
  exchange     String
  side         PositionSide
  quantity     Float
  entryPrice   Float
  currentPrice Float
  pnl          Float        @default(0)
  pnlPct       Float        @default(0)
  status       PositionStatus @default(OPEN)
  openedAt     DateTime     @default(now())
  closedAt     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  portfolioId  String
  portfolio    Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([symbol])
}

model Balance {
  id           String       @id @default(cuid())
  asset        String
  free         Float        @default(0)
  locked       Float        @default(0)
  exchange     String
  updatedAt    DateTime     @updatedAt

  portfolioId  String
  portfolio    Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, asset, exchange])
}

enum PositionSide {
  LONG
  SHORT
}

enum PositionStatus {
  OPEN
  CLOSED
  LIQUIDATED
}

// ============ TRADES & ORDERS ============

model Trade {
  id           String       @id @default(cuid())
  symbol       String
  exchange     String
  side         TradeSide
  quantity     Float
  entryPrice   Float
  exitPrice    Float?
  pnl          Float        @default(0)
  pnlPct       Float        @default(0)
  status       TradeStatus  @default(OPEN)
  fee          Float        @default(0)
  strategy     String?
  executedAt   DateTime     @default(now())
  closedAt     DateTime?
  createdAt    DateTime     @default(now())

  userId       String
  user         User         @relation(fields: [userId], references: [id])
  portfolioId  String
  portfolio    Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([portfolioId])
  @@index([symbol])
}

model Order {
  id              String       @id @default(cuid())
  exchangeOrderId String?
  symbol          String
  exchange        String
  side            TradeSide
  type            OrderType
  quantity        Float
  price           Float?
  stopPrice       Float?
  filledQty       Float        @default(0)
  avgFillPrice    Float?
  status          OrderStatus  @default(PENDING)
  timeInForce     TimeInForce  @default(GTC)
  fee             Float        @default(0)
  errorMessage    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  userId          String
  user            User         @relation(fields: [userId], references: [id])
  portfolioId     String
  portfolio       Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([portfolioId])
  @@index([status])
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum OrderType {
  MARKET
  LIMIT
  STOP
  STOP_LIMIT
  TRAILING_STOP
}

enum OrderStatus {
  PENDING
  SUBMITTED
  PARTIAL
  FILLED
  CANCELLED
  REJECTED
}

enum TimeInForce {
  GTC
  IOC
  FOK
  GTD
}

// ============ WATCHLIST ============

model Watchlist {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items     WatchlistItem[]
  createdAt DateTime @default(now())
}

model WatchlistItem {
  id           String   @id @default(cuid())
  symbol       String
  exchange     String
  sortOrder    Int      @default(0)
  alertAbove   Float?
  alertBelow   Float?
  watchlistId  String
  watchlist    Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@index([watchlistId])
}

// ============ AI AGENTS ============

model AIAgent {
  id          String       @id @default(cuid())
  name        String
  type        AgentType
  description String
  strategy    String
  riskLevel   RiskLevel    @default(MEDIUM)
  isActive    Boolean      @default(false)
  config      Json?
  performance Json?
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id])
  orgId       String?
  org         Organization? @relation(fields: [orgId], references: [id])
  executions  AgentExecution[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model AgentExecution {
  id            String   @id @default(cuid())
  agentId       String
  agent         AIAgent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  signals       Json?
  tradesExecuted Int     @default(0)
  pnl           Float    @default(0)
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  duration      Int?
}

enum AgentType {
  SCALPER
  SWING
  ARBITRAGE
  RISK_MANAGER
  SENTIMENT
  REBALANCER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

// ============ CREDENTIALS & SECURITY ============

model ExchangeCredential {
  id           String   @id @default(cuid())
  exchange     String
  label        String
  apiKey       String   // Encrypted
  apiSecret    String   // Encrypted
  passphrase   String?  // Encrypted (Coinbase)
  accountId    String?  // OANDA
  permissions  String[]
  isActive     Boolean  @default(true)
  testnet      Boolean  @default(true)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, exchange])
}

model Session {
  id              String   @id @default(cuid())
  token           String   @unique
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress       String?
  userAgent       String?
  twoFactorVerified Boolean @default(false)
  expiresAt       DateTime
  createdAt       DateTime @default(now())
}

// ============ NOTIFICATIONS ============

model Notification {
  id        String              @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  priority  NotificationPriority @default(NORMAL)
  data      Json?
  read      Boolean             @default(false)
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime            @default(now())
}

enum NotificationType {
  TRADE
  ALERT
  RISK
  SYSTEM
  AGENT
  DEPOSIT
  WITHDRAWAL
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

// ============ DEPLOYMENTS ============

model Deployment {
  id           String   @id @default(cuid())
  environment  String
  platform     String
  url          String?
  status       DeploymentStatus @default(PENDING)
  version      String
  logs         String?
  orgId        String?
  org          Organization? @relation(fields: [orgId], references: [id])
  deployedAt   DateTime @default(now())
}

enum DeploymentStatus {
  PENDING
  BUILDING
  SUCCESS
  FAILED
  CANCELLED
}
