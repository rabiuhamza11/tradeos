# TradeOS Environment Configuration

# ============ DATABASE ============
DATABASE_URL="postgresql://postgres:password@localhost:5432/tradeos?schema=public"
REDIS_URL="redis://localhost:6379"

# ============ AUTH ============
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
# Refresh token lifetime in days
REFRESH_TOKEN_DAYS="7"
# Idle session timeout in minutes (auto-logout after inactivity)
IDLE_TIMEOUT_MINUTES="30"
OAUTH_GOOGLE_CLIENT_ID=""
OAUTH_GOOGLE_CLIENT_SECRET=""
OAUTH_GITHUB_CLIENT_ID=""
OAUTH_GITHUB_CLIENT_SECRET=""

# ============ EXCHANGE API KEYS ============
# Binance Spot
BINANCE_API_KEY=""
BINANCE_API_SECRET=""
# Binance Futures
BINANCE_FUTURES_API_KEY=""
BINANCE_FUTURES_API_SECRET=""
# Coinbase Advanced
COINBASE_API_KEY=""
COINBASE_API_SECRET=""
COINBASE_PASSPHRASE=""
# Alpaca (US Stocks)
ALPACA_API_KEY=""
ALPACA_API_SECRET=""
ALPACA_API_URL="https://paper-api.alpaca.markets"
# OANDA (Forex)
OANDA_API_KEY=""
OANDA_ACCOUNT_ID=""

# ============ TRADING SETTINGS ============
EXCHANGE_TESTNET=true
MAX_POSITION_SIZE=50000
MAX_PORTFOLIO_EXPOSURE=0.80
MAX_SINGLE_TRADE_RISK=0.02
MAX_DAILY_LOSS=5000
MAX_OPEN_POSITIONS=20

# ============ AI ENGINE ============
OPENAI_API_KEY=""
AI_MODEL="gpt-4"
AI_TEMPERATURE=0.3

# ============ WEBSOCKET ============
WS_PORT=4001
WS_CORS_ORIGIN="http://localhost:3000"

# ============ SERVER ============
PORT=4000
CORS_ORIGIN="http://localhost:3000"
LOG_LEVEL="debug"

# ============ NOTIFICATIONS ============
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""

# ============ SECURITY ============
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
BCRYPT_ROUNDS=12
