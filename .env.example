# Database
DATABASE_URL=postgresql://tradeos:tradeos_secret@localhost:5432/tradeos_db

# Redis (for caching and queues)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-secure-random-string

# Encryption key for API key storage (must be 32 chars)
ENCRYPTION_KEY=tradeos-encryption-key-32chars

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# API
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Exchange Environment
# Set to "false" for LIVE trading, "true" for testnet/paper
EXCHANGE_TESTNET=true
EXCHANGE_LIVE=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ============ EXCHANGE API KEYS ============
# These auto-load on startup. Users can also add keys via the UI.

# Binance Spot (Crypto)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Binance Futures (Crypto futures/perpetuals with leverage)
BINANCE_FUTURES_API_KEY=
BINANCE_FUTURES_API_SECRET=

# Coinbase Advanced Trade (Crypto)
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_PASSPHRASE=

# Alpaca Markets (US Stocks, ETFs, Options)
# Get keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_API_SECRET=

# OANDA (Forex, CFDs, Commodities)
# Get key at https://www.oanda.com/account/your-account-id
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# ============ DEPLOYMENT ============
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
RENDER_DEPLOY_HOOK=
DOCKER_USERNAME=
DOCKER_PASSWORD=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TELEGRAM_BOT_TOKEN=

# AI
OPENAI_API_KEY=
